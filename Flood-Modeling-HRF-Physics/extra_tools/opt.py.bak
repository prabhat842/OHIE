import numpy as np
import cupy as cp
_xp = cp  # This version requires a GPU for performance
import matplotlib.pyplot as plt
import time
import gc
import warnings
from sklearn.manifold import Isomap
from scipy.spatial.distance import pdist, squareform
from scipy.sparse.csgraph import dijkstra
from dataclasses import dataclass, field
from typing import List, Tuple, Dict, Any

warnings.filterwarnings('ignore', category=UserWarning)
plt.style.use('seaborn-v0_8-whitegrid')

# ==============================================================================
# Part 1: The Physics Engine (from V15)
# ==============================================================================
print("Defining Part 1: The Physics Engine...")

@dataclass
class ModelConfig:
    NX: int = 64
    NY: int = 64
    LX: float = 200.0
    LY: float = 200.0
    T_END: float = 8.0

MODEL_CONF = ModelConfig()

@dataclass
class Grid:
    nx: int; ny: int; Lx: float; Ly: float
    def __post_init__(self):
        self.dx=self.Lx/self.nx; self.dy=self.Ly/self.ny; x=_xp.arange(self.nx)*self.dx+(0.5*self.dx); y=_xp.arange(self.ny)*self.dy+(0.5*self.dy)
        self.X,self.Y=_xp.meshgrid(x,y,indexing="ij"); kx=2*np.pi*_xp.fft.fftfreq(self.nx,d=self.dx); ky=2*np.pi*_xp.fft.fftfreq(self.ny,d=self.dy)
        self.KX,self.KY=_xp.meshgrid(kx,ky,indexing="ij")
    def ddx(self, f): return _xp.fft.ifft2(1j*self.KX*_xp.fft.fft2(f)).real
    def ddy(self, f): return _xp.fft.ifft2(1j*self.KY*_xp.fft.fft2(f)).real

@dataclass
class ExponentialFilter:
    alpha: float = 36.0; p: int = 8
    def apply(self, grid: Grid, f):
        kx_max,ky_max=np.pi/grid.dx,np.pi/grid.dy; kx_n,ky_n=grid.KX/(kx_max+1e-14),grid.KY/(ky_max+1e-14)
        eta=_xp.sqrt(kx_n**2+ky_n**2); sigma=_xp.exp(-self.alpha*(eta**self.p)); return _xp.fft.ifft2(_xp.fft.fft2(f)*sigma).real

@dataclass
class SWEParams:
    g: float=9.81; h_min: float=1e-4; cfl: float=0.15; dt_max: float=0.05

@dataclass
class HRFSolver:
    grid: Grid; prm: SWEParams; filt: ExponentialFilter; bed: _xp.ndarray = None
    def __post_init__(self): self.h,self.u,self.v,self.time=None,None,None,0.0; self.bed=_xp.zeros((self.grid.nx,self.grid.ny)) if self.bed is None else self.bed
    def initialize(self, h0, u0, v0): self.h,self.u,self.v,self.time=_xp.array(h0),_xp.array(u0),_xp.array(v0),0.0
    def rhs(self, h, u, v):
        hu,hv=h*u,h*v; p_term=0.5*self.prm.g*h*h+self.prm.g*h*self.bed
        dhdt=-(self.grid.ddx(hu)+self.grid.ddy(hv)); dudt=-(self.grid.ddx(hu*u)+self.grid.ddy(hv*u))-self.grid.ddx(p_term)/(h+1e-12)
        dvdt=-(self.grid.ddx(hu*v)+self.grid.ddy(hv*v))-self.grid.ddy(p_term)/(h+1e-12); return dhdt,dudt,dvdt
    def choose_dt(self): vmax=_xp.max(_xp.sqrt(self.u**2+self.v**2)+_xp.sqrt(self.prm.g*self.h)); dt_cfl=self.prm.cfl*min(self.grid.dx,self.grid.dy)/max(1e-6,vmax); return min(dt_cfl,self.prm.dt_max)
    def step(self):
        dt=self.choose_dt(); dh,du,dv=self.rhs(self.h,self.u,self.v); self.h+=dt*dh; self.u+=dt*du; self.v+=dt*dv
        self.h,self.u,self.v=self.filt.apply(self.grid,self.h),self.filt.apply(self.grid,self.u),self.filt.apply(self.grid,self.v)
        self.h[self.h<self.prm.h_min]=self.prm.h_min; self.time+=dt

def setup_circular_dam_break(grid,h_high,h_low,radius_frac=0.25):
    center_x,center_y=grid.Lx/2.0,grid.Ly/2.0; radius=grid.Lx*radius_frac
    condition=_xp.sqrt((grid.X-center_x)**2+(grid.Y-center_y)**2)<radius; h0=_xp.where(condition,h_high,h_low); return h0,_xp.zeros_like(h0),_xp.zeros_like(h0)

# ==============================================================================
# Part 2: The QCA Core (from V16.1)
# ==============================================================================
print("Defining Part 2: The QCA Core...")

@dataclass
class QuantumState:
    amplitudes: np.ndarray
    hypotheses: List[str]
    def __repr__(self): return " + ".join([f"({amp:.2f} | \"{hyp}\")" for amp, hyp in zip(self.amplitudes, self.hypotheses)])

@dataclass
class Experience:
    state_before: QuantumState
    action: Dict[str, Any]
    state_after: QuantumState
    reward: float = 0.0

class GeometricCausalEngine:
    def __init__(self, manifold_dim: int = 3):
        self.manifold_dim = manifold_dim
        self.experiences: List[Experience] = []
        self.manifold_coordinates: np.ndarray = None
        self.isomap = Isomap(n_components=self.manifold_dim, n_neighbors=5)
        self.manifold_is_stale = True

    def _get_transition_vectors(self) -> np.ndarray:
        vectors = []
        for exp in self.experiences:
            vec = np.concatenate([exp.state_before.amplitudes, exp.state_after.amplitudes])
            vectors.append(vec)
        return np.array(vectors)

    def learn_manifold(self):
        if len(self.experiences) < 7: return
        print("🧠 Engine is re-learning the manifold structure of causality...")
        transition_vectors = self._get_transition_vectors()
        self.manifold_coordinates = self.isomap.fit_transform(transition_vectors)
        self.manifold_is_stale = False

class Planner:
    def plan(self, engine: GeometricCausalEngine, start_experience_idx: int, goal_experience_idx: int) -> List[Dict[str, Any]]:
        if engine.manifold_coordinates is None or start_experience_idx is None or goal_experience_idx is None: return []
        print("🗺️ Planner is searching for a path on the causal manifold...")
        dist_matrix = squareform(pdist(engine.manifold_coordinates, 'euclidean'))
        _, predecessors = dijkstra(csgraph=dist_matrix, directed=False, indices=start_experience_idx, return_predecessors=True)
        path_indices = []
        current_node = goal_experience_idx
        while current_node != start_experience_idx and current_node != -9999 and len(path_indices) < 10:
            path_indices.append(current_node)
            current_node = predecessors[current_node]
        path_indices.append(start_experience_idx)
        path_indices.reverse()
        if not path_indices or len(path_indices) < 2: return [engine.experiences[goal_experience_idx].action]
        return [engine.experiences[i].action for i in path_indices]

class QCA:
    def __init__(self):
        self.engine = GeometricCausalEngine()
        self.planner = Planner()
        print("✅ QCA Core Initialized.")

    def find_closest_experience(self, current_q_state: QuantumState, by_reward: bool = False) -> int | None:
        if not self.engine.experiences: return None
        if by_reward: return np.argmax([exp.reward for exp in self.engine.experiences])
        else: return np.argmin([np.linalg.norm(current_q_state.amplitudes - exp.state_before.amplitudes) for exp in self.engine.experiences])

    def learn(self, experience: Experience):
        self.engine.experiences.append(experience)
        self.engine.manifold_is_stale = True

    def decide_plan(self, current_q_state: QuantumState) -> List[Dict[str, Any]]:
        if self.engine.manifold_is_stale: self.engine.learn_manifold()
        start_idx = self.find_closest_experience(current_q_state)
        goal_idx = self.find_closest_experience(current_q_state, by_reward=True)
        if start_idx is None or goal_idx is None: return []
        return self.planner.plan(self.engine, start_idx, goal_idx)

# ==============================================================================
# Part 3: The Adapters
# ==============================================================================
print("Defining Part 3: The Adapters...")

class FluidsEncoder:
    def _get_spectral_energy(self, h_fft, nx, ny, k_min_frac, k_max_frac):
        k_min_x,k_max_x=int(nx*k_min_frac),int(nx*k_max_frac); k_min_y,k_max_y=int(ny*k_min_frac),int(ny*k_max_frac)
        mask=_xp.zeros_like(h_fft,dtype=bool); outer_ring=_xp.ones_like(h_fft,dtype=bool); inner_ring=_xp.ones_like(h_fft,dtype=bool)
        outer_ring[k_max_x:-k_max_x,k_max_y:-k_max_y]=False; inner_ring[k_min_x:-k_min_x,k_min_y:-k_min_y]=False
        mask=outer_ring&inner_ring; return _xp.mean(_xp.abs(h_fft[mask])) if _xp.any(mask) else 0.0

    def encode(self, h_grid: _xp.ndarray) -> QuantumState:
        hypotheses = ['high_ripple', 'low_ripple', 'high_wave', 'low_wave']
        h_fft = _xp.fft.fftshift(_xp.fft.fft2(h_grid))
        nx, ny = h_grid.shape
        amplitudes = _xp.array([
            self._get_spectral_energy(h_fft,nx,ny,0.35,0.50),
            self._get_spectral_energy(h_fft,nx,ny,0.20,0.35),
            self._get_spectral_energy(h_fft,nx,ny,0.12,0.20),
            self._get_spectral_energy(h_fft,nx,ny,0.05,0.12)
        ])
        amplitudes /= (_xp.sum(amplitudes) + 1e-9)
        return QuantumState(amplitudes=amplitudes.get(), hypotheses=hypotheses) # .get() to move from GPU to CPU

class FluidsDecoder:
    def decode(self, action_step: dict) -> tuple:
        return action_step.get('strength', 0.0), action_step.get('cutoff_frac', 0.35)

def apply_spectral_damper(h, u, v, grid=None, strength=1.0, cutoff_frac=0.35):
    if grid is None or strength <= 1e-6: return h, u, v
    h_fft = _xp.fft.fft2(h)
    kx, ky = grid.KX, grid.KY
    k_magnitude = _xp.sqrt(kx**2 + ky**2)
    k_max = _xp.pi / grid.dx
    cutoff_k = cutoff_frac * k_max
    mask = _xp.exp(-(k_magnitude**2) / (2 * cutoff_k**2))
    h_fft_damped = h_fft * mask
    h_fft_blended = (1.0 - strength) * h_fft + strength * h_fft_damped
    h_corrected = _xp.fft.ifft2(h_fft_blended).real
    return h_corrected, u, v

# ==============================================================================
# Part 4: The Grand Unification Experiment
# ==============================================================================
print("Defining Part 4: The Grand Unification Experiment...")

def run_unified_experiment():
    print("\n" + "="*80 + "\n🔬 RUNNING UNIFIED EXPERIMENT WITH QCA (V17)\n" + "="*80)

    # 1. Setup
    qca = QCA()
    encoder = FluidsEncoder()
    decoder = FluidsDecoder()
    grid = Grid(nx=MODEL_CONF.NX, ny=MODEL_CONF.NY, Lx=MODEL_CONF.LX, Ly=MODEL_CONF.LY)
    solver = HRFSolver(grid, SWEParams(), ExponentialFilter())
    h0, u0, v0 = setup_circular_dam_break(grid, h_high=3.0, h_low=0.5)
    solver.initialize(h0, u0, v0)

    current_plan = []
    history = {'t': [], 'h': [], 'reward': [], 'strength': [], 'cutoff': []}

    # 2. Main Simulation Loop
    start_time = time.time()
    while solver.time < MODEL_CONF.T_END:
        state_before_raw = solver.h.copy()
        q_state_before = encoder.encode(state_before_raw)

        if not current_plan:
            current_plan = qca.decide_plan(q_state_before)
            if not current_plan:
                str_exp, cut_exp = np.random.rand() * 0.5, np.random.rand() * 0.3 + 0.15
                current_plan = [{'action': 'damp', 'strength': str_exp, 'cutoff_frac': cut_exp}]

        action_to_take = current_plan.pop(0)
        strength, cutoff = decoder.decode(action_to_take)

        h_c, u_c, v_c = apply_spectral_damper(solver.h, solver.u, solver.v, grid, strength, cutoff)
        solver.h, solver.u, solver.v = h_c, u_c, v_c
        solver.step()

        state_after_raw = solver.h.copy()
        q_state_after = encoder.encode(state_after_raw)
        reward = q_state_before.amplitudes[0] - q_state_after.amplitudes[0]
        experience = Experience(
            state_before=q_state_before,
            action=action_to_take,
            state_after=q_state_after,
            reward=reward
        )
        qca.learn(experience)

        history['t'].append(solver.time)
        history['h'].append(cp.asnumpy(solver.h).mean())
        history['reward'].append(reward)
        history['strength'].append(strength)
        history['cutoff'].append(cutoff)

    print(f"\n✅ Simulation complete. Total runtime: {time.time() - start_time:.2f}s")
    gc.collect()

    # 3. Visualization
    fig, axs = plt.subplots(3, 1, figsize=(15, 12), sharex=True)
    fig.suptitle('Project Chimera V17 - AI Control of Fluid Simulation', fontsize=16)

    axs[0].plot(history['t'], history['h'], label='Mean Water Height', color='cornflowerblue')
    axs[0].set_ylabel('Mean Height (m)')
    axs[0].set_title('Simulation State: Conservation of Mass')
    axs[0].grid(True, linestyle='--', alpha=0.6)

    axs[1].plot(history['t'], history['reward'], label='Reward (Ripple Reduction)', color='lightcoral', alpha=0.8)
    axs[1].set_ylabel('Instantaneous Reward')
    axs[1].set_title('AI Reward Signal: Learning to Stabilize')
    axs[1].grid(True, linestyle='--', alpha=0.6)
    
    ax3_s = axs[2]
    ax3_c = ax3_s.twinx()
    ax3_s.plot(history['t'], history['strength'], label='Strength', color='tab:blue', alpha=0.9)
    ax3_c.plot(history['t'], history['cutoff'], label='Cutoff', color='tab:red', linestyle='--', alpha=0.9)
    ax3_s.set_xlabel('Time (s)')
    ax3_s.set_ylabel('Damper Strength', color='tab:blue')
    ax3_c.set_ylabel('Damper Cutoff Fraction', color='tab:red')
    ax3_s.set_title('AI Controller Actions: Learned Strategy')
    ax3_s.grid(True, linestyle='--', alpha=0.6)
    
    lines_s, labels_s = ax3_s.get_legend_handles_labels()
    lines_c, labels_c = ax3_c.get_legend_handles_labels()
    ax3_c.legend(lines_s + lines_c, labels_s + labels_c, loc='upper right')

    fig.tight_layout(rect=[0, 0.03, 1, 0.96])
    plt.show()

# ==============================================================================
# Final Step: Execute the experiment
# ==============================================================================
# This line checks if we are in a notebook environment and runs the experiment.
run_unified_experiment()



